{
  "name": "app-store",
  "version": "1.1.0",
  "description": "Una tienda de aplicaciones y juegos para Linux y Windows",
  "private": true,
  "type": "module",
  "main": "main.js",
  "homepage": "https://tu-sitio.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Solaez/UnknownGestor.git"
  },
  "author": "Tu Nombre <tu@email.com>",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --linux --win",
    "release": "npm run build && electron-builder --linux --win --publish always",
    "clean": "rm -rf dist release_builds"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tw-animate-css": "^1.4.0",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.0",
    "vite": "^6.4.1"
  },
  "build": {
    "appId": "com.appstore.linux",
    "productName": "AppStore",
    "directories": {
      "output": "release_builds"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "src/data/mods.js"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Tu Nombre <tu@email.com>",
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Solaez",
        "repo": "UnknownGestor",
        "releaseType": "release"
      }
    ],
    "asar": true
  }
}
